# ============================================
# RapidMart — Environment Variables Template
# Copy this file to .env.local and fill values
# ============================================

# MongoDB Connection URI
# Local Docker: mongodb://rapidmart_admin:rapidmart_secret@localhost:27017/rapidmart?authSource=admin
# Atlas:        mongodb+srv://<user>:<pass>@cluster0.mongodb.net/rapidmart
MONGO_URI=

# NextAuth.js
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App Config
NEXT_PUBLIC_APP_NAME=RapidMart
NEXT_PUBLIC_APP_URL=http://localhost:3000
